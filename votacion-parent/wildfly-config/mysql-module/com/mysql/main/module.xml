<?xml version="1.0" encoding="UTF-8"?>
<!--
  Modulo del driver MySQL para WildFly.
  Ruta de instalacion:
    $WILDFLY_HOME/modules/com/mysql/main/module.xml
  Junto a este archivo, copiar el JAR del connector:
    mysql-connector-j-8.4.0.jar  (descargar de Maven Central)
-->
<module xmlns="urn:jboss:module:1.9" name="com.mysql">
    <resources>
        <resource-root path="mysql-connector-j-8.4.0.jar"/>
    </resources>
    <dependencies>
        <module name="jakarta.transaction.api"/>
        <module name="java.sql"/>
    </dependencies>
</module>
